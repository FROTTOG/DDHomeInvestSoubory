# D&D HOMEINVEST - Apache konfigurace pro Endora hosting
# HTTPS redirect nastavte v Endora admin panelu, NE zde.

Options -Indexes
RewriteEngine On
RewriteBase /

# Next.js static export - fallback na index.html pro SPA routing
# (pouze pro cesty kde soubor nebo složka neexistuje)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.html [L]

# Gzip komprese
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

# Vypnutí cache pro HTML (vždy načte aktuální verzi)
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
  </FilesMatch>
  
  # Krátká cache pro statické assety (5 minut) - hash v názvu zajistí invalidaci při změně
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
    Header set ETag ""
  </FilesMatch>
  
  # Krátká cache pro obrázky (10 minut)
  <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=600, must-revalidate"
    Header set ETag ""
  </FilesMatch>
</IfModule>

# Povolení ETag pro lepší cache validaci
<IfModule mod_headers.c>
  Header unset ETag
  FileETag None
</IfModule>
